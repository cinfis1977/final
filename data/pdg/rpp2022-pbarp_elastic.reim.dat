body{font-family:Verdana,Geneva,sans-serif;-webkit-text-size-adjust:none;padding:0;margin:0;background-color:#fff}.title{font-weight:700;font-size:19px;color:#666}#sitename-border{color:#fff;height:106px;width:100%;border-left:solid 1px #fff;border-right:solid 1px #fff}#content{color:#2a2a2a;min-height:480px;min-width:505px;position:relative;width:520px;background:linear-gradient(0deg,rgba(255,255,255,1) 20%,rgba(255,254,202,1) 95%);margin-top:-6px;border-top:0;border:solid 1px #fff}.drop-shadow{position:relative;width:520px;padding:0;margin:0 0 0;background:#fff;-webkit-box-shadow:0 1px 4px rgba(0,0,0,.3),0 0 40px rgba(0,0,0,.1) inset;-moz-box-shadow:0 1px 4px rgba(0,0,0,.3),0 0 40px rgba(0,0,0,.1) inset;box-shadow:0 1px 4px rgba(0,0,0,.3),0 0 40px rgba(0,0,0,.1) inset}.drop-shadow:after,.drop-shadow:before{content:"";position:absolute;z-index:-2}.drop-shadow p{font-size:16px;font-weight:700}.curved:before{top:10px;bottom:10px;left:0;right:50%;-webkit-box-shadow:0 0 15px rgba(0,0,0,.6);-moz-box-shadow:0 0 15px rgba(0,0,0,.6);box-shadow:0 0 15px rgba(0,0,0,.6);-moz-border-radius:10px/100px;border-radius:10px/100px}.curved-vt-2:before{right:0}.curved-hz-1:before{top:50%;bottom:0;left:10px;right:10px;-moz-border-radius:100px/10px;border-radius:100px/10px}.curved-hz-2:before{top:0;bottom:0;left:10px;right:10px;-moz-border-radius:100px/10px;border-radius:100px/10px}#wrap{clear:both;padding:0;text-align:left}h2{font-size:24px;font-family:Arial,Helvetica,sans-serif;font-weight:700}a{font-weight:700;text-decoration:none}a:hover{color:#ff9d9d;text-decoration:underline}p{line-height:1.5em;margin:0 0 30px}#text{width:75%;font-family:Arial,Helvetica,sans-serif}
</style>


